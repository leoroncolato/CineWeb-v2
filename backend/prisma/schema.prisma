// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model Cinema {
  id          Int      @id @default(autoincrement()) // O diagrama pede 'long', no Prisma 'Int' ou 'BigInt' atendem bem.
  nome        String
  endereco    String   // Corrigi o erro de digitação da imagem ("enderco")
  
  // Relacionamentos vindos do losango preto (Composição/Agregação)
  listaSalas  Sala[]
  listaFilmes Filme[]
  listaSessao Sessao[]

  @@map("cinemas")
}

model Sala {
  id          Int      @id @default(autoincrement())
  numero      Int
  capacidade  Int
  poltronas   Json     // aqui um JSON de matriz (ex: [[1,0],[1,1]])
  
  // Relacionamento com Cinema
  cinemaId    Int?
  cinema      Cinema?  @relation(fields: [cinemaId], references: [id], onDelete: Cascade)
  
  // Relacionamento com Sessão
  sessoes     Sessao[]

  @@map("salas")
}

// Enum para o Gênero do filme
enum Genero {
  ACAO
  COMEDIA
  DRAMA
  TERROR
  FICCAO
}
model Filme {
  id                  Int       @id @default(autoincrement())
  titulo              String
  sinopse             String?   @db.Text
  classificacao       String
  duracao             DateTime  // O diagrama pede Date. (Obs: Para duração, 'Int' em minutos costuma ser melhor, mas mantive fiel à imagem).
  elenco              String?   @db.Text
  genero              Genero    // Alterado para usar o Enum conforme a imagem
  dataInicialExibicao DateTime  @db.Date
  dataFinalExibicao   DateTime  @db.Date
  
  cinemaId            Int?
  cinema              Cinema?   @relation(fields: [cinemaId], references: [id], onDelete: Cascade)
  sessoes             Sessao[]

  @@map("filmes")
}


model Sessao {
  id               Int      @id @default(autoincrement())
  horarioExibicao  DateTime 
  filmeId          Int

  filme            Filme    @relation(fields: [filmeId], references: [id], onDelete: Cascade)
  
  salaId           Int
  sala             Sala     @relation(fields: [salaId], references: [id], onDelete: Cascade)

  cinemaId         Int?
  cinema           Cinema?  @relation(fields: [cinemaId], references: [id], onDelete: Cascade)

  ingressos        Ingresso[]

  @@map("sessoes")
}

model Ingresso {
  id           Int      @id @default(autoincrement())
  valorInteira Float    
  valorMeia    Float
  
  sessaoId     Int
  sessao       Sessao   @relation(fields: [sessaoId], references: [id], onDelete: Cascade)
  
  pedidoId     Int?
  pedido       Pedido?  @relation(fields: [pedidoId], references: [id])

  @@map("ingressos")
}

enum TipoIngresso {
  INTEIRA
  MEIA
}

model LancheCombo {
  id            Int      @id @default(autoincrement())
  nome          String
  descricao     String?  @db.Text
  valorUnitario Float
  qtUnidade     Int
  subtotal      Float
  
  // Para atrelar ao Pedido 
  pedidoId      Int?
  pedido        Pedido?  @relation(fields: [pedidoId], references: [id])

  @@map("lanches_combos")
}

// Tabela pivô para associar Lanches a Ingressos
model Pedido {
  id         Int           @id @default(autoincrement())
  qtInteira  Int
  qtMeia     Int
  valorTotal Float

  // Modelamos com 1:N (Um pedido tem vários ingressos e vários lanches).
  ingressos  Ingresso[]
  lanches    LancheCombo[]

  @@map("pedidos")
}
